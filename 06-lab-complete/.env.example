# LLM
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Security
AGENT_API_KEY=change-me-in-production

# Rate limiting & cost guard
RATE_LIMIT_PER_MIN=10
MONTHLY_BUDGET_USD=10.0
COST_PER_REQUEST_USD=0.01

# Service discovery
# Docker: dùng service name
REGISTRY_URL=http://registry:10000
# Local dev: dùng localhost
# REGISTRY_URL=http://localhost:10000

# Ports
REGISTRY_PORT=10000
CUSTOMER_AGENT_PORT=10100
LAW_AGENT_PORT=10101
TAX_AGENT_PORT=10102
COMPLIANCE_AGENT_PORT=10103
